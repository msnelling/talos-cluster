{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "automergeType": "pr",
  "packageRules": [
    {
      "description": "Require manual review for major version bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Exclude date-based tags (2021.x.x etc) for LinuxServer images that use application semver",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/linuxserver/tautulli",
        "ghcr.io/linuxserver/transmission"
      ],
      "allowedVersions": "!/^20\\d{2}\\./"
    }
  ]
}
